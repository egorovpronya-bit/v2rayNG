<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Назад"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Logo area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAQANet"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Версия 1.0.2"
                android:textColor="#4F6EF7"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сервис защиты приватности\nи безопасного соединения"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Info rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_default"
            android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Telegram"
                    android:textColor="#6B7280" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:id="@+id/layout_tg_channel"
                    android:text="@SAQANet_bot" android:textColor="#4F6EF7" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Сайт"
                    android:textColor="#6B7280" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:id="@+id/layout_soure_ccode"
                    android:text="saqanet.ru" android:textColor="#4F6EF7" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Протоколы"
                    android:textColor="#6B7280" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VLESS · Trojan" android:textColor="#E5E7EB" android:textSize="12sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Конфиденциальность"
                    android:textColor="#6B7280" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:id="@+id/layout_privacy_policy"
                    android:text="Политика" android:textColor="#4F6EF7" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Open source"
                    android:textColor="#6B7280" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:id="@+id/layout_oss_licenses"
                    android:text="Лицензии" android:textColor="#4F6EF7" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/layout_feedback"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="СООБЩИТЬ О ПРОБЛЕМЕ"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_app_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 SAQANet"
            android:textColor="#252540"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</LinearLayout>

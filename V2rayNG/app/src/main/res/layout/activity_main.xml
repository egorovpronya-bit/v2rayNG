<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12"
    android:fitsSystemWindows="true">

    <!-- TOPBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="9dp">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SAQANet"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="9dp" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/bg_topbar_icon"
            android:src="@drawable/ic_settings_24dp"
            android:tint="#9CA3AF"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:layout_marginEnd="11dp"
            android:contentDescription="@string/title_settings" />

        <ImageButton
            android:id="@+id/btn_add"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/bg_add_button"
            android:src="@drawable/ic_add_24dp"
            android:tint="#FFFFFF"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="@string/saqanet_add" />

    </LinearLayout>

    <!-- SHIELD BAR — centered -->
    <LinearLayout
        android:id="@+id/shield_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_shield_inactive">

        <View
            android:id="@+id/shield_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_red" />

        <TextView
            android:id="@+id/tv_shield_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Не активен"
            android:textColor="#EF4444"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="9dp" />

    </LinearLayout>

    <!-- POWER AREA — фиксированная высота, кнопка всегда на одном месте -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="330dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_power_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нажмите чтобы включить"
                android:textColor="#6B7280"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <!-- Power button with glow -->
            <FrameLayout
                android:id="@+id/btn_power"
                android:layout_width="226dp"
                android:layout_height="226dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/power_glow"
                    android:layout_width="226dp"
                    android:layout_height="226dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_power_glow"
                    android:visibility="invisible" />

                <FrameLayout
                    android:id="@+id/power_btn_circle"
                    android:layout_width="168dp"
                    android:layout_height="168dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_power_btn">

                    <ImageView
                        android:id="@+id/iv_power_icon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_power" />

                </FrameLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_connection_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отключён"
                android:textColor="#4B5563"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tv_update_banner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FACC15"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="#1FFACC15" />

        </LinearLayout>

    </FrameLayout>

    <!-- TRAFFIC CARD -->
    <LinearLayout
        android:id="@+id/traffic_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_traffic_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ ПЕРЕДАНО"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_traffic_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#E5E7EB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ ПОЛУЧЕНО"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_traffic_download"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#E5E7EB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_user_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="ID: SN-—"
            android:textColor="#374151"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- SERVER LIST — scrollable, fills remaining space -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:overScrollMode="never"
        android:fadeScrollbars="true">

        <LinearLayout
            android:id="@+id/server_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp" />

    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/saqanet_back"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Shield icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textSize="64sp"
                    android:textColor="#EF4444" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saqanet_not_working_title"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="14dp" />

            <!-- Step 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="22dp" android:layout_height="22dp"
                    android:text="1" android:textColor="#4F6EF7" android:textSize="10sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_step_num"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="10dp"
                    android:text="@string/saqanet_step1"
                    android:textColor="#9CA3AF" android:textSize="12sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="22dp" android:layout_height="22dp"
                    android:text="2" android:textColor="#4F6EF7" android:textSize="10sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_step_num"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="10dp"
                    android:text="@string/saqanet_step2"
                    android:textColor="#9CA3AF" android:textSize="12sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="22dp" android:layout_height="22dp"
                    android:text="3" android:textColor="#4F6EF7" android:textSize="10sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_step_num"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="10dp"
                    android:text="@string/saqanet_step3"
                    android:textColor="#9CA3AF" android:textSize="12sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="22dp" android:layout_height="22dp"
                    android:text="4" android:textColor="#4F6EF7" android:textSize="10sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_step_num"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="10dp"
                    android:text="@string/saqanet_step4"
                    android:textColor="#9CA3AF" android:textSize="12sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Step 5 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="20dp">
                <TextView android:layout_width="22dp" android:layout_height="22dp"
                    android:text="5" android:textColor="#4F6EF7" android:textSize="10sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_step_num"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="10dp"
                    android:text="@string/saqanet_step5"
                    android:textColor="#9CA3AF" android:textSize="12sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <Button
                android:id="@+id/btn_open_bot"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/saqanet_go_to_bot"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

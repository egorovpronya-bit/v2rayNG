<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/saqanet_back"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/saqanet_sub_title"
            android:textColor="#E5E7EB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="60dp" android:layout_height="1dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/saqanet_sub_subtitle"
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ ОДИН ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saqanet_sub_plan_one"
                android:textColor="#4B5563"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:paddingStart="4dp" />

            <LinearLayout
                android:id="@+id/plan_one_30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_active"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_1month" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_30days_unlimited" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="99 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_one_90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_3months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_90days_single" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="277 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_one_180"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_6months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_180days_single" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="554 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- ═══ ПАРА ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saqanet_sub_plan_pair"
                android:textColor="#4B5563"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:paddingStart="4dp" />

            <LinearLayout
                android:id="@+id/plan_pair_30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_1month" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_30days_pair" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="199 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_pair_90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_3months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_90days_pair" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="557 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_pair_180"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_6months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_180days_pair" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 114 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- ═══ СЕМЕЙНЫЙ ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/saqanet_sub_plan_family"
                    android:textColor="#4B5563"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"
                    android:paddingStart="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" @string/saqanet_sub_beneficial"
                    android:textColor="#10B981"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_1month" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_30days_family" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="299 ₽" android:textColor="#10B981" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="6dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_3months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_90days_family" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="837 ₽" android:textColor="#10B981" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_180"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="16dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_6months" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/saqanet_sub_180days_family" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 674 ₽" android:textColor="#10B981" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Pay button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btn_pay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/saqanet_sub_pay"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>

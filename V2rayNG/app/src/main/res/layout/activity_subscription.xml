<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Назад"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Выбор подписки"
            android:textColor="#E5E7EB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="60dp" android:layout_height="1dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выберите план и период"
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp" />

    <!-- Plans list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Personal section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЛИЧНАЯ"
                android:textColor="#4B5563"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:paddingStart="4dp" />

            <LinearLayout
                android:id="@+id/plan_30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_active"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="30 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1 устройство" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="149 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="90 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1 устройство" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="399 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_180"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_default"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="180 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1 устройство" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="699 ₽" android:textColor="#4F6EF7" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Family section -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СЕМЕЙНАЯ"
                    android:textColor="#4B5563"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"
                    android:paddingStart="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="НОВОЕ"
                    android:textColor="#8B5CF6"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card_family" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="30 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="до 3 устройств" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="349 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="90 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="до 3 устройств" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="849 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/plan_family_180"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_family"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="180 дней" android:textColor="#E5E7EB" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="до 3 устройств" android:textColor="#6B7280" android:textSize="11sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 499 ₽" android:textColor="#8B5CF6" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Pay button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btn_pay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ОПЛАТИТЬ В @SAQANet_bot"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
